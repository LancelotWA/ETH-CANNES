{
  "name": "eth-cannes-fintech",
  "version": "1.0.0",
  "private": true,
  "description": "Crypto-native social payments monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @ethcannes/frontend & npm run start:dev --workspace @ethcannes/backend",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "format": "npm run format --workspaces"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.2.4"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@walletconnect/modal": "^2.7.0",
    "qrcode": "^1.5.4",
    "tailwind": "^4.0.0",
    "viem": "^2.47.10",
    "wagmi": "^3.6.0",
    "zustand": "^5.0.12"
  }
}
